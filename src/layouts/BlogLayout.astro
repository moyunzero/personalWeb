---
import BaseLayout from './BaseLayout.astro';
import type { SeoInput } from '../lib/seo';

interface Props {
    seo: SeoInput;
}

const { seo } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout seo={seo}>
    <header class="border-b border-zinc-800">
        <div class="container flex items-center justify-between py-4">
            <a href={base} class="text-lg font-semibold text-zinc-100 hover:text-white">
                {seo.title.split(' · ')[0]}
            </a>
            <nav class="flex gap-4 text-sm text-zinc-400">
                <a href={`${base}blog/`} class="hover:text-zinc-100">博客</a>
            </nav>
        </div>
    </header>
    <main class="container py-10">
        <slot />
    </main>
    <footer class="border-t border-zinc-800 py-8 text-center text-sm text-zinc-500">
        <p>© {new Date().getFullYear()} 墨韵</p>
    </footer>
</BaseLayout>
