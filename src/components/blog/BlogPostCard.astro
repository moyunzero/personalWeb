---
import { getCategoryLabel } from '../../blog/getCategories.js';

interface Props {
    slug: string;
    title: string;
    description?: string;
    publishedAt: string;
    categories?: string[];
    tags?: string[];
    coverImage?: string;
}

const {
    slug,
    title,
    description,
    publishedAt,
    categories = [],
    tags = [],
    coverImage,
} = Astro.props;

const badgeClass =
    'inline-block max-w-[9rem] truncate rounded px-2 py-1 text-xs';
const date = new Date(publishedAt);
const formattedDate = Number.isNaN(date.getTime())
    ? publishedAt
    : date.toLocaleDateString('zh-CN', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
      });
const base = import.meta.env.BASE_URL;
const href = `${base}blog/${slug}/`;
---

<a
    href={href}
    class="flex h-full flex-col overflow-hidden rounded-lg bg-zinc-800 transition-colors hover:bg-zinc-700"
>
    {
        coverImage && (
            <img
                src={coverImage}
                alt=""
                class="h-40 w-full shrink-0 object-cover"
                loading="lazy"
            />
        )
    }
    <div class="flex flex-1 flex-col p-6">
        <h2 class="mb-3 line-clamp-2 h-14 text-xl font-semibold leading-7">
            {title}
        </h2>
        <p class="mb-3 line-clamp-3 h-[4.5rem] text-sm leading-6 text-zinc-400">
            {description || '暂无简介'}
        </p>
        <div class="mb-3 h-7 shrink-0 overflow-hidden">
            <div class="flex flex-wrap gap-2">
                {
                    categories.length > 0
                        ? categories.map((categoryId) => (
                              <span
                                  class={`${badgeClass} bg-violet-500/20 text-violet-300`}
                                  title={getCategoryLabel(categoryId)}
                              >
                                  {getCategoryLabel(categoryId)}
                              </span>
                          ))
                        : (
                              <span
                                  class="invisible px-2 py-1 text-xs"
                                  aria-hidden="true"
                              >
                                  —
                              </span>
                          )
                }
            </div>
        </div>
        <div class="mb-4 h-7 shrink-0 overflow-hidden">
            <div class="flex flex-wrap gap-2">
                {
                    tags.length > 0
                        ? tags.slice(0, 3).map((tag) => (
                              <span
                                  class={`${badgeClass} bg-sky-500/20 text-sky-300`}
                                  title={tag}
                              >
                                  {tag}
                              </span>
                          ))
                        : (
                              <span
                                  class="invisible px-2 py-1 text-xs"
                                  aria-hidden="true"
                              >
                                  —
                              </span>
                          )
                }
            </div>
        </div>
        <time class="text-sm text-zinc-500" datetime={publishedAt}>
            {formattedDate}
        </time>
    </div>
</a>
