---
import { projects } from '../../data/projects';
import ProjectCard from './ProjectCard.astro';
---

<section id="work" class="section">
    <div class="container">
        <h2 class="headline-2 mb-8 reveal-up">项目经历</h2>
        <div class="grid gap-x-4 gap-y-5 grid-cols-[repeat(auto-fill,_minmax(280px,_1fr))]">
            {
                projects.map((project) => (
                    <ProjectCard {...project} classes="reveal-up" />
                ))
            }
        </div>
    </div>
</section>
