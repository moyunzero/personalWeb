---
interface Props {
    imgSrc: string;
    title: string;
    description?: string;
    tags: string[];
    projectLink: string;
    classes?: string;
}

const { imgSrc, title, description, tags, projectLink, classes = '' } = Astro.props;
const hasLink = projectLink && projectLink.trim() !== '';
---

<div
    class={`relative p-4 rounded-2xl bg-zinc-800 hover:bg-zinc-700/50 active:bg-zinc-700/60 ring-1 ring-inset ring-zinc-50/5 transition-colors cursor-pointer ${classes}`}
>
    <figure class="relative aspect-[16/10] rounded-lg mb-4 overflow-hidden bg-zinc-900/30">
        <img
            src={imgSrc}
            alt={title}
            loading="lazy"
            decoding="async"
            class="w-full h-full object-contain rounded-lg bg-zinc-900/50"
        />
    </figure>
    <div class="flex items-start justify-between gap-4">
        <div class="flex-1 min-w-0">
            <h3 class="title-1 mb-3">{title}</h3>
            {description ? (
                <p class="text-sm text-zinc-400 mb-3 leading-relaxed">{description}</p>
            ) : null}
            <div class="flex flex-wrap items-center gap-2">
                {tags.map((label) => (
                    <span class="h-8 text-sm text-zinc-400 bg-zinc-50/5 grid items-center px-2 rounded-lg">
                        {label}
                    </span>
                ))}
            </div>
        </div>
        {hasLink ? (
            <div class="w-11 h-11 rounded-lg grid place-items-center bg-sky-400 text-zinc-950 shrink-0">
                <span class="material-symbols-rounded" aria-hidden="true">arrow_outward</span>
            </div>
        ) : null}
    </div>
    {hasLink ? (
        <a
            href={projectLink}
            target="_blank"
            rel="noopener noreferrer"
            class="absolute inset-0"
            aria-label={`查看项目: ${title}`}
        >
            <span class="sr-only">查看项目: {title}</span>
        </a>
    ) : (
        <div class="absolute inset-0" aria-label={`项目: ${title}（暂无链接）`}>
            <span class="sr-only">项目: {title}（暂无链接）</span>
        </div>
    )}
</div>
