{
  "ci": {
    "collect": {
      "url": ["http://localhost:4321/personalWeb/"],
      "numberOfRuns": 3,
      "settings": {
        "preset": "perf",
        "onlyCategories": ["performance"]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.85 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }]
      }
    }
  }
}
