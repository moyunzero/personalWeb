# ============ 聊天机器人后端 API ============
# personal-gpt 部署在 Vercel 上的 /api/chat endpoint
# Vite 要求所有暴露给浏览器的环境变量必须以 VITE_ 前缀
#
# 本地开发：
#   1. 复制此文件为 .env.local（已被 .gitignore 忽略，安全）
#      cp .env.example .env.local
#   2. 改成你自己的 API 地址（或保持默认指向我的 Vercel 部署）
#
# 生产构建（GitHub Pages）：
#   通过 .github/workflows/deploy.yml 的 env 字段注入，
#   或在仓库 Settings → Variables 中设置 VITE_CHAT_API_URL。
#
# ⚠️  注意：此 URL 会被打包进前端 bundle，对所有访客可见。
#          因此 *不要* 在这里放真正的 API Key / Token / 私密 endpoint。
#          所有敏感凭证应放在 personal-gpt 后端（Vercel 环境变量）。
VITE_CHAT_API_URL=https://xxx.vercel.app/api/chat

# ============ Notion 博客同步（仅本地 / CI，勿提交到 Git）============
# 在 https://www.notion.so/my-integrations 创建 Integration 后复制 Token
# 在 Notion 中打开博客数据库 → ··· → 连接 → 选择你的 Integration
# 数据库 ID：打开数据库页面，URL 中 .../DATABASE_ID?v=...
NOTION_TOKEN=secret_xxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 可选：若自动解析失败，可填 data source ID（数据库 retrieve 返回的 data_sources[0].id）
# NOTION_DATA_SOURCE_ID=

# 可选：属性名与 Notion 列名不一致时覆盖（默认见 scripts/notion-sync.mjs）
# NOTION_PROP_TITLE=Title
# NOTION_PROP_STATUS=Status
# NOTION_STATUS_PUBLISHED=Published,已发布
# NOTION_DEFAULT_AUTHOR=墨韵
